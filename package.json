{
  "name": "skilltree-cli",
  "version": "0.2.0",
  "description": "Visual skill tree viewer for Claude Code and other AI tool skills installed on your machine.",
  "license": "MIT",
  "author": "Bladpoet",
  "repository": {
    "type": "git",
    "url": "https://github.com/Bladpoet/skilltree-cli.git"
  },
  "homepage": "https://github.com/Bladpoet/skilltree-cli#readme",
  "keywords": ["claude", "ai", "skills", "cli", "skill-tree", "claude-code", "codex", "cursor"],
  "type": "module",
  "bin": {
    "skilltree": "bin/cli.js"
  },
  "files": [
    "bin/",
    "dist/assets/",
    "dist/fonts/",
    "dist/index.html",
    "dist/sounds/",
    "generate.js",
    "claude-skills-icons/"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "skills:generate": "node generate.js",
    "skills:watch": "node generate.js --watch",
    "dev:real": "npm run skills:generate && vite",
    "build": "vite build",
    "prepack": "npm run build",
    "dev": "vite"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.1.12",
    "@vitejs/plugin-react": "4.7.0",
    "lucide-react": "0.487.0",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "svgo": "^4.0.1",
    "tailwindcss": "4.1.12",
    "tw-animate-css": "1.3.8",
    "use-sound": "^5.0.0",
    "vite": "6.3.5"
  },
  "pnpm": {
    "overrides": {
      "vite": "6.3.5"
    }
  }
}
